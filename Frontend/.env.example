# API base URL (required in production if not using ABS production domains)
# Local:
VITE_API_URL=http://localhost:5001

# Google OAuth (sign-in / sign-up) – Web client ID from Google Cloud Console
# Create OAuth 2.0 Client ID (Web application), add authorized JavaScript origins (e.g. http://localhost:5173)
# VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# Production (myapp.africanbusinesssuite.com): set to your API URL. If unset, app auto-uses https://api.africanbusinesssuite.com when served from myapp.africanbusinesssuite.com
# VITE_API_URL=https://api.africanbusinesssuite.com

# API timeout in ms (optional, default 60000)
# VITE_API_TIMEOUT=60000

# Sabito frontend URL (optional, for opening Sabito in browser)
# VITE_SABITO_URL=http://localhost:5175

# WebSocket / Socket.IO (optional). On myapp.africanbusinesssuite.com, disabled unless set to true (Vercel API has no socket.io).
# VITE_WS_ENABLED=false  # force off (local or any host)
# VITE_WS_ENABLED=true   # force on (e.g. self-hosted API with Socket.IO)
