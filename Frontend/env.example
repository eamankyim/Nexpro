# Local dev: leave VITE_API_URL unset — the app uses same-origin /api via Vite proxy (avoids CORS and macOS :5000/AirPlay).
# Optional: Vite probes http://127.0.0.1:5000–5010 for the backend; override if needed:
# VITE_API_URL=http://127.0.0.1:5001
# Direct cross-origin API (skip proxy): VITE_API_DIRECT=true and VITE_API_URL=http://127.0.0.1:5001
# Sabito Frontend URL (for navigation/opening Sabito in browser)
VITE_SABITO_URL=http://localhost:5175


