# Backend API URL (must match Backend/.env demo DB — same as web local)
# - iOS Simulator / Android Emulator: http://localhost:5001
# - Physical device: LAN IP from `npm run show-api-url` (not localhost)
# - Production: https://api.africanbusinesssuite.com
# After changing: npx expo start -c
EXPO_PUBLIC_API_URL=http://localhost:5001

# Production example:
# EXPO_PUBLIC_API_URL=https://api.africanbusinesssuite.com

# Public storefront URL (for "View storefront" links)
# EXPO_PUBLIC_STOREFRONT_URL=https://www.absghana.com
