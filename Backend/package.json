{
  "name": "printing-press-backend",
  "version": "1.0.0",
  "description": "ABS (African Business Suite) - Business Management System Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/migrate.js",
    "db:check": "node scripts/test-db-connection.js",
    "db:sync-vercel": "node scripts/sync-canonical-database-to-vercel.js",
    "db:restore-production-vercel": "node scripts/restore-production-database-on-vercel.js",
    "migrate:recurring": "node migrations/create-recurring-journals.js",
    "migrate:subscription-payments": "node migrations/create-subscription-payments-table.js",
    "migrate:trial-defaults": "node migrations/backfill-trial-plan-defaults.js",
    "migrate:shop-default": "node migrations/add-isDefault-to-shops.js",
    "migrate:shop-type": "node migrations/add-shop-type-to-shops.js",
    "vercel:build": "npm run migrate",
    "seed": "node utils/seeder.js",
    "seed-admin": "node utils/seedAdmin.js",
    "seed-platform-admin": "node utils/seedPlatformAdmin.js",
    "seed-pricing": "node utils/seedPricing.js",
    "reset": "node utils/resetForProduction.js",
    "generate-invoices": "node utils/generateMissingInvoices.js",
    "test-reports": "node scripts/test-report-date-filters.js",
    "generate:platform-email-key": "node scripts/generate-platform-email-encryption-key.js",
    "update:platform-email-key": "node scripts/update-platform-email-encryption-key.js",
    "update:superadmin-email": "node scripts/update-superadmin-email.js",
    "verify:user-email": "node scripts/verify-user-email.js",
    "delete:tenant-products": "node scripts/delete-tenant-products.js",
    "import:sulas-products": "node scripts/import-sulas-products.js",
    "import:products-csv": "node scripts/import-products-csv-for-tenant.js",
    "copy:products-between-shops": "node scripts/copy-products-between-tenant-shops.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration",
    "verify:invoice-discount": "node scripts/verify-invoice-discount.js",
    "adjust:invoice-payment": "node scripts/adjust-invoice-payment.js",
    "load:k6": "k6 run ./load-tests/backend-load-test.js",
    "load:k6:100": "PROFILE=100 k6 run ./load-tests/backend-load-test.js",
    "load:k6:200": "PROFILE=200 k6 run ./load-tests/backend-load-test.js",
    "load:k6:300": "PROFILE=300 k6 run ./load-tests/backend-load-test.js"
  },
  "keywords": [
    "printing",
    "press",
    "management",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.16.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "qs": "^6.13.0",
    "sequelize": "^6.35.2",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
