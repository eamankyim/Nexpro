# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use your Neon PostgreSQL connection string from https://console.neon.tech
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
# SQL_DEBUG=true - set to log SQL queries (useful for debugging, adds latency)

# Alternative unpooled connection (if needed)
# DATABASE_URL_UNPOOLED=postgresql://username:password@host:5432/database?sslmode=require

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# bcrypt rounds for password hashing (default: 10)
# Use 8 for faster signup when DB is remote (~100–150ms saved). Slightly weaker but still secure (OWASP acceptable).
# BCRYPT_ROUNDS=8

# CORS Configuration
# For multiple origins, separate with commas (no spaces)
# Example: http://localhost:3000,https://your-frontend.vercel.app,https://your-frontend.netlify.app
# For mobile testing on same WiFi: add your LAN URL (e.g. http://192.168.0.124:3000). Run `npm run show-ip` in Frontend.
# ShopWISE Africa production: allow app and website to call API at api.shopwiseafrica.com
#   CORS_ORIGIN=https://myapp.shopwiseafrica.com,https://shopwiseafrica.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://192.168.0.124:3000

# Google OAuth (sign-in / sign-up)
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials (Web application, add authorized JS origins and redirect URIs)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL (for redirects, invite links, email links)
# Local: http://localhost:3000
# ShopWISE Africa production (app): https://myapp.shopwiseafrica.com
#   FRONTEND_URL=https://myapp.shopwiseafrica.com
FRONTEND_URL=http://localhost:3000

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Sabito Integration
# Sabito API/Backend URL (for SSO token verification and webhooks)
# For localhost testing: http://localhost:4002
# For production: https://api.sabito.com
SABITO_API_URL=http://localhost:4002
SABITO_API_KEY=96f39d4b9514addf4c8f08fc38a88db869bd382e16337edbfe46197859ba1e73

# Sabito Customer Sync Configuration
# Enable/disable periodic sync of customers from Sabito
# Set to 'false' to disable automatic syncing
SABITO_SYNC_ENABLED=true

# Sabito sync interval (cron expression)
# Default: every 6 hours (0 */6 * * *)
# Examples:
#   Every hour: '0 * * * *'
#   Every 12 hours: '0 */12 * * *'
#   Daily at midnight: '0 0 * * *'
#   Every 30 minutes: '*/30 * * * *'
SABITO_SYNC_INTERVAL=0 */6 * * *

# Run sync on server startup (true/false)
# Set to 'false' to skip initial sync on startup
SABITO_SYNC_ON_STARTUP=true

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_API_VERSION=v21.0

# Platform Email (for system emails paid by the platform: password reset, welcome, etc.)
# Business-to-customer emails (invoices, receipts) use each business's own Settings > Email config; they pay.
# PLATFORM_EMAIL_PROVIDER=smtp
# SMTP (when PLATFORM_EMAIL_PROVIDER=smtp):
# PLATFORM_SMTP_HOST=smtp.example.com
# PLATFORM_SMTP_PORT=587
# PLATFORM_SMTP_USER=noreply@yourdomain.com
# PLATFORM_SMTP_PASSWORD=your_password
# PLATFORM_EMAIL_FROM=noreply@yourdomain.com
# PLATFORM_EMAIL_FROM_NAME=ShopWISE
# SendGrid: PLATFORM_EMAIL_PROVIDER=sendgrid, PLATFORM_SENDGRID_API_KEY=...
# AWS SES: PLATFORM_EMAIL_PROVIDER=ses, PLATFORM_SES_ACCESS_KEY_ID=..., PLATFORM_SES_SECRET_ACCESS_KEY=..., PLATFORM_SES_REGION=us-east-1

# Platform SMS (optional – shared SMS for all tenants)
# When set, tenants without their own SMS config can still send receipts via the platform account.
# Tenant SMS settings (Settings > SMS) override platform when configured.
# PLATFORM_SMS_ENABLED=true
# PLATFORM_SMS_PROVIDER=twilio
# Twilio (when PLATFORM_SMS_PROVIDER=twilio):
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890
# Or use PLATFORM_TWILIO_ACCOUNT_SID, PLATFORM_TWILIO_AUTH_TOKEN, PLATFORM_TWILIO_FROM_NUMBER
# Africa's Talking (when PLATFORM_SMS_PROVIDER=africas_talking):
# AFRICAS_TALKING_API_KEY=your_api_key
# AFRICAS_TALKING_USERNAME=your_username
# AFRICAS_TALKING_FROM_NUMBER=NEXPRO
# Or use PLATFORM_AFRICAS_TALKING_API_KEY, PLATFORM_AFRICAS_TALKING_USERNAME, PLATFORM_AFRICAS_TALKING_FROM

# OpenAI API (for AI-powered report analysis and fallback for assistant chat)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (Claude) – if set, assistant chat uses Claude instead of OpenAI
ANTHROPIC_API_KEY=

# MTN Mobile Money API Configuration
# Get credentials from https://momodeveloper.mtn.com
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_COLLECTION_URL=https://sandbox.momodeveloper.mtn.com/collection
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_API_USER=your_api_user_uuid
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=https://your-domain.com/api/webhooks/mtn-momo

# Airtel Money API Configuration
# Get credentials from https://developers.airtel.africa
AIRTEL_MONEY_BASE_URL=https://openapi.airtel.africa
AIRTEL_MONEY_CLIENT_ID=your_client_id
AIRTEL_MONEY_CLIENT_SECRET=your_client_secret
AIRTEL_MONEY_ENVIRONMENT=sandbox
AIRTEL_MONEY_CALLBACK_URL=https://your-domain.com/api/webhooks/airtel-money