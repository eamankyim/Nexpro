# Server Configuration
# macOS: AirPlay Receiver may bind :5000 (not this API). Use PORT=5001 or disable AirPlay in System Settings.
PORT=5000
NODE_ENV=development

# Database — local backend should use the demo database when no local DB exists.
# Copy the demo Backend DATABASE_URL value from Vercel/project secrets into Backend/.env.
# Do not commit the real demo database URL.
DATABASE_URL=postgresql://username:password@demo-db-host/neondb?sslmode=require

# Neon local dev (optional):
# NEON_USE_WEBSOCKET=false — default; use TCP pooler URL locally (recommended)
# NEON_USE_WEBSOCKET=true — only if TCP :5432 is blocked (corporate firewall); uses @neondatabase/serverless + ws
# DB_POOL_ACQUIRE_MS=120000 — pool acquire timeout ms (default 120000 for Neon in development, 60000 in production)
# Do not add channel_binding=require to DATABASE_URL; node-pg can hang on that parameter.

# Production API uses a separate DB — see .env.production.example (not loaded by local server)
# SQL_DEBUG=true - set to log SQL queries (useful for debugging, adds latency)

# Alternative unpooled connection (if needed)
# DATABASE_URL_UNPOOLED=postgresql://username:password@host:5432/database?sslmode=require

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# bcrypt rounds for password hashing (default: 10)
# Use 8 for faster signup when DB is remote (~100–150ms saved). Slightly weaker but still secure (OWASP acceptable).
# BCRYPT_ROUNDS=8

# CORS Configuration
# For multiple origins, separate with commas (no spaces)
# Local dev defaults also include localhost/127.0.0.1 :3000 and :5173 when NODE_ENV=development
# Example: http://localhost:3000,https://your-frontend.vercel.app,https://your-frontend.netlify.app
# For mobile testing on same WiFi: add your LAN URL (e.g. http://192.168.0.124:3000). Run `npm run show-ip` in Frontend.
# ABS / African Business Suite production: allow app and website to call API
#   CORS_ORIGIN=https://myapp.africanbusinesssuite.com,https://africanbusinesssuite.com,https://absghana.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://192.168.0.124:3000

# Google OAuth (sign-in / sign-up)
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials (Web application)
# Authorized JavaScript origins must include your dashboard and storefront URLs, e.g. http://localhost:3000 and http://localhost:3002
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL (for redirects, invite links, email links)
# Local: http://localhost:3000
# ABS production (app): https://myapp.africanbusinesssuite.com
# Production: set to your app URL (no trailing slash), e.g. https://myapp.africanbusinesssuite.com
#   FRONTEND_URL=https://myapp.africanbusinesssuite.com
FRONTEND_URL=http://localhost:3000

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Sabito Integration
# Sabito API/Backend URL (for SSO token verification and webhooks)
# For localhost testing: http://localhost:4002
# For production: https://api.sabito.com
SABITO_API_URL=http://localhost:4002
SABITO_API_KEY=96f39d4b9514addf4c8f08fc38a88db869bd382e16337edbfe46197859ba1e73

# Sabito Customer Sync Configuration
# Enable/disable periodic sync of customers from Sabito
# Set to 'false' to disable automatic syncing
SABITO_SYNC_ENABLED=true

# Sabito sync interval (cron expression)
# Default: every 6 hours (0 */6 * * *)
# Examples:
#   Every hour: '0 * * * *'
#   Every 12 hours: '0 */12 * * *'
#   Daily at midnight: '0 0 * * *'
#   Every 30 minutes: '*/30 * * * *'
SABITO_SYNC_INTERVAL=0 */6 * * *

# Run sync on server startup (true/false)
# Set to 'false' to skip initial sync on startup
SABITO_SYNC_ON_STARTUP=true

# Sabito marketplace trade assurance
SABITO_MARKETPLACE_COMMISSION_PERCENT=1
SABITO_MARKETPLACE_COMMISSION_FIXED_FEE=0
SABITO_TRADE_ASSURANCE_AUTO_RELEASE_HOURS=72

# Marketplace automatic Paystack transfers (seller payouts after fulfillment checks)
# Runs auto-release of held payments, then initiates Paystack transfers for available payouts.
MARKETPLACE_PAYOUT_SCHEDULER_ENABLED=true
MARKETPLACE_PAYOUT_SCHEDULER_CRON=*/10 * * * *
MARKETPLACE_PAYOUT_BATCH_LIMIT=20

# Sabito Store storefront (Paystack checkout callback URL)
# STOREFRONT_URL=http://localhost:3002

# "Online Store" custom domain product (customer-owned domain -> single-store template).
# This is the CNAME target merchants are told to point their domain to. Falls back to
# STOREFRONT_URL's host if unset. DNS/SSL verification is manual for now — see
# Backend/controllers/storeController.js (updateDomain / resolveStoreByDomain).
# STOREFRONT_CNAME_TARGET=store.abs.app

# Paystack (primary payments: subscriptions, invoices, POS, storefront checkout – card, bank, mobile money)
# Get API keys from https://dashboard.paystack.com/#/settings/developer
# Test keys: sk_test_..., pk_test_ | Live keys: sk_live_..., pk_live_
# PAYSTACK_SECRET_KEY=sk_live_xxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxx
# API base must be https://api.paystack.co (NOT api.paystack.com — .com returns Cloudflare HTML to server clients / 403).
# PAYSTACK_BASE_URL=https://api.paystack.co
# PAYSTACK_SUBACCOUNT_CODE=ACCT_xxx  (platform subaccount; optional)
# Plan codes (from Paystack dashboard or sync script):
# PAYSTACK_PLAN_STARTER_MONTHLY=PLN_xxx
# PAYSTACK_PLAN_STARTER_YEARLY=PLN_xxx
# PAYSTACK_PLAN_PROFESSIONAL_MONTHLY=PLN_xxx
# PAYSTACK_PLAN_PROFESSIONAL_YEARLY=PLN_xxx
# PAYSTACK_PLATFORM_FEE_PERCENT=2  (optional; default 2)
# Bank list for Receive payments: PAYSTACK_BANK_COUNTRY=nigeria or ghana (optional; if unset, tries Nigeria then Ghana)

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_API_VERSION=v21.0

# Platform Email (system emails only – company pays: verifications, password reset, etc.)
# Provider and credentials can be saved in Admin Settings > Communications > Platform email provider.
# Required before saving platform email secrets. Generate once with:
#   openssl rand -hex 32
# or:
#   npm run generate:platform-email-key
# Keep this exact 64-hex-char value stable across deploys. If it changes, saved platform email
# credentials cannot be decrypted and must be re-entered.
# PLATFORM_EMAIL_CREDENTIALS_ENCRYPTION_KEY=your_64_hex_char_key
# ENV values below are fallback/bootstrap only. Tenant-facing emails (invoices, receipts, reminders) use
# each business's own Settings > Email; they configure and pay for their provider.
# Temporary Gmail SMTP option:
# PLATFORM_EMAIL_PROVIDER=gmail
# PLATFORM_GMAIL_USER=your_gmail_address@gmail.com
# PLATFORM_GMAIL_APP_PASSWORD=your_gmail_app_password
# PLATFORM_EMAIL_FROM=your_gmail_address@gmail.com
# PLATFORM_EMAIL_FROM_NAME=ABS
# SendGrid option:
# PLATFORM_EMAIL_PROVIDER=sendgrid
# PLATFORM_SENDGRID_API_KEY=your_sendgrid_api_key
# PLATFORM_EMAIL_FROM=info@africanbusinesssuite.com
# PLATFORM_EMAIL_FROM_NAME=ABS
# APP_NAME=ABS (used when PLATFORM_EMAIL_FROM_NAME not set)
# Alternatives: PLATFORM_EMAIL_PROVIDER=smtp (PLATFORM_SMTP_HOST, PLATFORM_SMTP_USER, PLATFORM_SMTP_PASSWORD, etc.)
#   or mailjet, ses – see emailService.getPlatformConfig()

# Tenant SMS/Email/WhatsApp: tenants configure in Settings > Integrations (Termii, Arkesel, Twilio, Africa's Talking).
# When a tenant has no SMS config, platform SMS (Arkesel or Mnotify) can send customer messages with a monthly per-tenant quota.

# Platform SMS (Admin Settings > Communications > Platform SMS)
# Choose active provider (arkesel | mnotify), save API keys + sender IDs for each, and switch without a deploy.
# Tenants without own SMS use the active provider with monthly limits.
# Optional Mnotify base URL override (default https://api.mnotify.com/api):
# MNOTIFY_BASE_URL=https://api.mnotify.com/api
# Required before saving platform SMS secrets (can reuse the email encryption key or set a dedicated one):
# PLATFORM_SMS_CREDENTIALS_ENCRYPTION_KEY=your_64_hex_char_key
# Or reuse: PLATFORM_EMAIL_CREDENTIALS_ENCRYPTION_KEY=your_64_hex_char_key

# OpenAI API (legacy/optional)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (Claude) – required for AI-powered Smart Report analysis and assistant chat
ANTHROPIC_API_KEY=
#
# Encrypt per-tenant Anthropic API keys at rest (Settings > AI). Required before tenants can save workspace AI keys.
# Generate: openssl rand -hex 32   (must be exactly 64 hex characters)
# AI_CREDENTIALS_ENCRYPTION_KEY=

# Optional: Direct MTN / Airtel / Hubtel Mobile Money APIs
# Used for tenant-direct Ghana MoMo collection (priority: Hubtel → tenant MTN → platform MTN → Paystack MoMo).
# Card checkout stays on Paystack. Leave unset if you only use Paystack.
#
# MTN Mobile Money (optional platform fallback): https://momodeveloper.mtn.com
# Prefer per-tenant Collection API keys in Settings → Payments → Merchant ID.
# Platform env is NOT used when a tenant has Merchant ID without keys (avoids mis-settlement).
# MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_MOMO_COLLECTION_URL=https://sandbox.momodeveloper.mtn.com/collection
# MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
# MTN_MOMO_API_USER=your_api_user_uuid
# MTN_MOMO_API_KEY=your_api_key
# MTN_MOMO_ENVIRONMENT=sandbox
# MTN_MOMO_CALLBACK_URL=https://your-domain.com/api/webhooks/mtn-momo
#
# Encrypt per-tenant MTN + Hubtel credentials at rest (Settings → Payments).
# Generate: openssl rand -hex 32   (must be exactly 64 hex characters)
# MOMO_CREDENTIALS_ENCRYPTION_KEY=
#
# Hubtel Receive Money (tenant Client ID/Secret stored in Settings → Payments → Hubtel).
# HUBTEL_RECEIVE_MONEY_URL=https://rmp.hubtel.com/merchantaccount/merchants
# HUBTEL_TXN_STATUS_URL=https://api-txnstatus.hubtel.com/transactions
# Public HTTPS callback Hubtel will POST to (must be reachable from the internet):
# HUBTEL_CALLBACK_URL=https://your-domain.com/api/webhooks/hubtel
# If HUBTEL_CALLBACK_URL is unset, callback is derived from API_PUBLIC_URL / BACKEND_PUBLIC_URL / APP_URL + /api/webhooks/hubtel
# API_PUBLIC_URL=https://your-api-domain.com
#
# Airtel Money (optional): https://developers.airtel.africa
# AIRTEL_MONEY_BASE_URL=https://openapi.airtel.africa
# AIRTEL_MONEY_CLIENT_ID=your_client_id
# AIRTEL_MONEY_CLIENT_SECRET=your_client_secret
# AIRTEL_MONEY_ENVIRONMENT=sandbox
# AIRTEL_MONEY_CALLBACK_URL=https://your-domain.com/api/webhooks/airtel-money