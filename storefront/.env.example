# Backend API origin (no /api suffix). Dev Vite proxy prefers 5002, then 5000/5001, then 5003–5010.
# Keep this explicit when the backend binds PORT=5002 so stale local backends on other ports do not win.
VITE_API_URL=http://localhost:5002
VITE_DASHBOARD_URL=http://localhost:3000
VITE_STOREFRONT_URL=http://localhost:3002

# Optional: the storefront also fetches GOOGLE_CLIENT_ID from /api/auth/config.
# Set this when you want Vite to render Google sign-in before the config request finishes.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
