# Backend API origin (no /api suffix)
EXPO_PUBLIC_API_URL=http://localhost:5001

# Google OAuth client IDs (web client ID must match backend GOOGLE_CLIENT_ID)
# If unset, the app loads GOOGLE_CLIENT_ID from GET /api/auth/config at runtime.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Optional native client IDs (defaults to EXPO_PUBLIC_GOOGLE_CLIENT_ID on each platform)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# EAS project ID for push notifications and builds
EAS_PROJECT_ID=
